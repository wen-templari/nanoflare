DATABASE_URL=postgres://app_user:change-me@127.0.0.1:5432/app_db?sslmode=disable
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=app-assets
MINIO_SECURE=false
NANOFLARE_TRAEFIK_TOKEN=change-me
NANOFLARE_RUNNER_TOKEN=change-me

NANOFLARE_BASE_HOSTNAME=workers.example.test

# Uncomment and replace these when enabling browser OIDC login for protected apps.
# NANOFLARE_OIDC_ISSUER=https://auth.example.com/oidc
# NANOFLARE_OIDC_AUDIENCE=your-audience
# NANOFLARE_OIDC_CLIENT_ID=your-client-id
# NANOFLARE_OIDC_CLIENT_SECRET=your-client-secret
# NANOFLARE_OIDC_PUBLIC_URL=https://platform.example.test:8443
# NANOFLARE_OIDC_COOKIE_DOMAIN=.example.test
# NANOFLARE_OIDC_EMAIL_CLAIM=email

NANOFLARE_SECRET_KEY=replace-with-64-char-hex-secret

# Optional override for the CLI and Vite dev proxy.
# NANOFLARED_URL=http://127.0.0.1:8080
